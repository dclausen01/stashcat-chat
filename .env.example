# Backend server port (default: 3001)
PORT=3001

# Stashcat/schul.cloud API base URL
STASHCAT_BASE_URL=https://api.stashcat.com/

# Node environment
NODE_ENV=production

# Session-Token-Verschlüsselung (AES-256-GCM master key).
#
# WICHTIG: In Produktion zwingend setzen!
# Ohne SESSION_SECRET generiert der Server bei jedem Start einen zufälligen
# Schlüssel. Damit werden alle bisher ausgegebenen Tokens ungültig, Nutzer
# müssen sich neu anmelden, und die stashcat-api registriert dabei jedes Mal
# ein neues Gerät (= "neues Gerät angemeldet"-Mail an den Nutzer).
#
# Wert generieren mit:   openssl rand -hex 32
# Format: 64 Hex-Zeichen (= 32 Bytes / 256 Bit).
# Einmal setzen und NIE wieder ändern. Bei Verdacht auf Leak: neu generieren —
# dann müssen sich alle Nutzer einmalig neu anmelden.
SESSION_SECRET=

# ── Mobile-Bridge / Push (Flutter shell) ─────────────────────────────────────
# Path to a Google service-account JSON with the
# `firebase.messaging` scope. Without this file FCM dispatch is disabled and
# only browser SSE delivery is used.
FCM_SERVICE_ACCOUNT=/etc/bbzchat/firebase-admin.json

# Set to "false" to fully disable the push dispatcher even if a service account
# is present (useful for local development).
PUSH_ENABLED=true

# Coalescing window in milliseconds. Bursts of messages within this window are
# collapsed into a single "N neue Nachrichten" notification per user.
PUSH_BATCH_MS=2000

# ── Externe Dienste (Nextcloud / OnlyOffice) ────────────────────────────────
# Basis-URL der Nextcloud-Instanz. Wird sowohl backend-seitig (WebDAV-Calls,
# OnlyOffice-Download) als auch front-end-seitig (Link-Erkennung in
# Channel-Beschreibungen, Editor-Platzhalter) verwendet. Ohne abschließenden
# Slash. Wenn nicht gesetzt, fällt der Server auf die BBZ-Default-URL zurück.
NEXTCLOUD_URL=https://cloud.bbz-rd-eck.de

# Basis-URL des OnlyOffice Document Servers. Wird für die Embedded-Editor-
# Konfiguration genutzt. Ohne abschließenden Slash.
ONLYOFFICE_URL=https://office.bbz-rd-eck.de

# Geheimnis für die JWT-Signierung der OnlyOffice-Editor-Konfiguration.
# MUSS gesetzt sein, sonst lehnt OnlyOffice die Editor-Sitzung ab.
# Wert generieren mit:   openssl rand -hex 32
ONLYOFFICE_JWT_SECRET=

# Öffentlich erreichbare Basis-URL dieses Chat-Servers. Wird in der
# OnlyOffice-Editor-Konfiguration für Download-Callback-URLs verwendet, damit
# der OnlyOffice-Server die Datei beim Chat-Backend abholen kann.
PUBLIC_URL=https://chat.bbz-rd-eck.com
